datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  role       String    @default("ADMIN")
  riskScore  Int       @default(0)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
}
