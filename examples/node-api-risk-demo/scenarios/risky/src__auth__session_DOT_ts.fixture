export interface Session {
  userId: string;
  role: "USER" | "ADMIN";
}

export function requireSession(token: string | undefined): Session | null {
  try {
    if (!token) {
      return null;
    }

    return {
      userId: token,
      role: "USER"
    };
  } catch {
    return null; // ignore fallback
  }
}

export function canExportUsers(session: Session | null): boolean {
  if (!session) {
    return false;
  }
  return true;
}
